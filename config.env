# 内核源码地址
KERNEL_SOURCE=https://github.com/nzlnice/Kernel_Xiaomi_SM8150_R

# 内核源码分支
KERNEL_SOURCE_BRANCH=rapheus

# 内核编译配置
KERNEL_CONFIG=raphael_defconfig

# 内核打包名字，自定义，支持英文数字
KERNEL_ZIP_NAME=raphael_miuicx_lxc-docker_kernel

# 是否开启kvm
ENABLE_KVM=false

# 是否开启lxc-docker，true即可
ENABLE_LXC_DOCKER=true

# 选择要打包的内核镜像文件
KERNEL_IMAGE_NAME=Image.gz

# 是否需要LLVM=1 LLVM_IAS=1参数
LLVM_CONFIG=n

# 是否需要切换python2，一般不需要，false即可
SWITCH_PYTHON=false

# 是否需要dtbo，一般不需要，false即可
NEED_DTBO=false

# ksu部分
ENABLE_KERNELSU=true
KERNELSU_TAG=main